{
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "target": "ES6",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "newLine": "lf",
    "strict": true,
    "skipLibCheck": true
  },
  "typedocOptions": {
    "out": "docs",
    "gitRemote": "docs",
    "gitRevision": "master",
    "entryPoints": ["src/index.ts"],
    "includeVersion": true
  },
  "exclude": ["node_modules", "src/**/*.d.ts"]
}
